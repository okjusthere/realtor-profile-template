# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/kevv_agent

# ─── Auth (Google OAuth) ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secret for session tokens (change in production!)
JWT_SECRET=dev-jwt-secret-change-me-in-production

# ─── Domain Configuration ───────────────────────────────────────────
# Agent public-facing pages (where visitors see agent profiles)
# Production example: https://agents.kevvrealty.com
AGENT_DOMAIN=http://localhost:3000

# Agent dashboard / configuration interface
# Production example: https://app.kevvrealty.com
DASHBOARD_URL=http://localhost:3000

# Fallback (used if AGENT_DOMAIN or DASHBOARD_URL not set)
APP_URL=http://localhost:3000

# ─── AI / Chat ───────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ─── Search (Tavily) ────────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Storage (S3-compatible) ─────────────────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
